# Copy this file to .env for local development (never commit the real .env).
# On Render/Railway, set this in the host's Environment settings instead.

GOOGLE_MAPS_API_KEY=paste-your-distance-matrix-key-here

# Browser key for Maps JavaScript API + Places API + Directions API.
# This one is sent to the browser, so it MUST be HTTP-referrer restricted in
# Google Cloud (locked to your Render domain, e.g. https://delivery-planner-ky3b.onrender.com/*).
GOOGLE_MAPS_BROWSER_KEY=paste-your-referrer-restricted-browser-key-here

# Optional — the host usually sets PORT automatically.
# PORT=3000
